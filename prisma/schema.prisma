generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  password      String?            // Nullable for OAuth-only users
  role          String             @default("LEADER") // ADMIN_MASTER, ADMIN, LEADER
  ministryId    String?
  ministry      Ministry?          @relation(fields: [ministryId], references: [id])
  accounts      Account[]
  sessions      Session[]
  reservations  SpaceReservation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ministry {
  id           String             @id @default(cuid())
  name         String             @unique
  requirements EventRequirement[]
  users        User[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Event {
  id              String   @id @default(cuid())
  title           String
  description     String?
  date            DateTime
  startTime       String?
  endTime         String?
  location        String?
  responsible     String?
  minister        String?  // Quem vai ministrar
  worship         String?  // Quem vai cantar
  groupId         String?  // Used to tie recurring events together
  recurrenceRule  String?  // Optional: RRULE string
  isRecurring     Boolean  @default(false)
  
  requirements    EventRequirement[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventRequirement {
  id          String   @id @default(cuid())
  eventId     String
  ministryId  String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ministry    Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([eventId, ministryId])
}

model PlatformSettings {
  id              String @id @default("default")
  siteTitle       String @default("Calendário de Eventos")
  primaryColor    String @default("#1e3a8a")
  accentColor     String @default("#f59e0b")
  siteLogo        String? 
  
  pdfTitle        String @default("A G E N D A")
  pdfSubtitle     String @default("Igreja Batista Lagoinha")
  pdfLogo         String?
  pdfTitleAlign   String @default("center") 
  
  updatedAt       DateTime @updatedAt
}

model Space {
  id            String             @id @default(cuid())
  name          String
  description   String?
  reservations  SpaceReservation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SpaceReservation {
  id          String   @id @default(cuid())
  spaceId     String
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String   
  startTime   String
  endTime     String
  title       String   
  status      String   @default("PENDING") 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
